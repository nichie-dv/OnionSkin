{
	"geode": "5.5.3",
	"version": "v1.3.2",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "nichie.onion_skin",
	"name": "Onion Skin",
	"description": "Turns editor layers into an onion skin tool",

	"developer": "nichie",
	"links": {
		"homepage": "https://nichie.dev",
		"source": "https://github.com/nichie-dv/OnionSkin"
	},
	

	"dependencies": {
		"geode.node-ids": ">=1.23.0"
	},
	"tags": [
		"editor",
		"offline"
	],
	"resources": {
        "sprites": [
            "resources/onionBtn_on.png",
			"resources/onionBtn_off.png"
        ]
    },

	"settings": {
        "main-title": {
            "type": "title",
            "name": "Color Settings"
        },
        "change-colors": {
			"type": "bool",
			"name": "Change Object Colors",
			"default": true
		},
        "past-color": {
            "name": "Past Frames",
            "type": "rgb",
            "default": "#f00",
			"description": "Change what color past frames show up as."
        },
		"future-color": {
            "name": "Future Frames",
            "type": "rgb",
            "default": "#00f",
			"description": "Change what color future frames show up as."
        },
		"rendering-title": {
            "type": "title",
            "name": "Rendering Settings"
        },
        "show-timestamp": {
			"type": "bool",
			"name": "Playback Timestamp",
            "description": "Show playback timestamp in editor. Shows in top left corner.",
			"default": true
		},
		"show-past": {
			"type": "bool",
			"name": "Show Past Frames",
			"default": true
		},
		"show-future": {
			"type": "bool",
			"name": "Show Future Frames",
			"default": true
		},
		"frame-depth": {
            "name": "Frame Cutoff",
			"description": "Change how many past and future frames will be displayed.",
            "type": "int",
            "default": 5,
            "min": 1,
            "max": 50,
            "control": {
                "slider": true
            }
        },
		"max-opacity": {
            "name": "Maximum Frame Opacity",
            "type": "int",
            "default": 35,
            "min": 0,
            "max": 100,
            "control": {
                "slider": true
            }
        },
		"min-opacity": {
            "name": "Minimum Frame Opacity",
            "type": "int",
            "default": 0,
            "min": 0,
            "max": 100,
            "control": {
                "slider": true
            }
        },
        "keybinds-title": {
            "type": "title",
            "name": "Keybind Settings"
        },
        "onion-enable-keybind": { 
            "name": "Toggle Onion Skin",
            "type": "keybind",
            "default": "Shift+F7"
        },
        "playback-enable-keybind": { 
            "name": "Toggle Animation Playback",
            "type": "keybind",
            "default": "Shift+F8"
        },
        "render-past-keybind": { 
            "name": "Render Past Frames",
            "type": "keybind",
            "default": "Shift+F9"
        },
        "render-future-keybind": { 
            "name": "Render Future Frames",
            "type": "keybind",
            "default": "Shift+F10"
        }
        
    }   
}
